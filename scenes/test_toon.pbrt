# ============================================================
# Simple toon shading test scene for pbrt-v4
# ============================================================

# Camera position, target, and up direction
LookAt 0 2.5 7
       0 0.8 0
       0 1 0

Camera "perspective"
    "float fov" [40]

Film "rgb"
    "string filename" ["toon-test.png"]
    "integer xresolution" [640]
    "integer yresolution" [480]

PixelFilter "box"
    "float xradius" [0.5]
    "float yradius" [0.5]

Sampler "halton" "integer pixelsamples" 128

# Custom toon integrator
# The integrator currently accepts only this parameter.
Integrator "toon"
    "integer level" [4]

WorldBegin

# ------------------------------------------------------------
# Directional light
#
# Light travels from "from" toward "to".
# This direction produces visible light bands on the spheres.
# ------------------------------------------------------------

# Weak blue-gray environment illumination
LightSource "infinite"
    "rgb L" [0.22 0.25 0.3]
    "float scale" [1]

# Main directional light
LightSource "distant"
    "rgb L" [3 3 3]
    "point3 from" [-3 6 4]
    "point3 to" [0 0 0]


# ------------------------------------------------------------
# Ground plane
#
# Two triangles forming a square from (-5, 0, -5)
# to (5, 0, 5).
# ------------------------------------------------------------

AttributeBegin

    Material "diffuse"
        "rgb reflectance" [0.65 0.65 0.65]

    Shape "trianglemesh"
        "point3 P" [
            -5 0 -5
             5 0 -5
             5 0  5
            -5 0  5
        ]
        "integer indices" [
            0 2 1
            0 3 2
        ]

AttributeEnd


# ------------------------------------------------------------
# Main red sphere
# ------------------------------------------------------------

AttributeBegin

    Translate -0.7 1 0

    Material "diffuse"
        "rgb reflectance" [0.8 0.12 0.08]

    Shape "sphere"
        "float radius" [1]

AttributeEnd


# ------------------------------------------------------------
# Smaller blue sphere
#
# It helps test object overlap and cast shadows.
# ------------------------------------------------------------

AttributeBegin

    Translate 1.15 0.65 0.35

    Material "diffuse"
        "rgb reflectance" [0.08 0.25 0.8]

    Shape "sphere"
        "float radius" [0.65]

AttributeEnd


# ------------------------------------------------------------
# Small yellow sphere in the background
# ------------------------------------------------------------

AttributeBegin

    Translate 0.85 0.4 -1.65

    Material "diffuse"
        "rgb reflectance" [0.85 0.55 0.05]

    Shape "sphere"
        "float radius" [0.4]

AttributeEnd